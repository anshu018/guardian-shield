<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Progress Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="System Services"
                android:textSize="18sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvStepIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Step 1 of 6"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp"/>

            <!-- Customized horizontal ProgressBar with 2563eb blue theme -->
            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:max="6"
                android:progress="1"
                android:progressTint="@color/primary"
                android:progressBackgroundTint="@color/card_background"/>
        </LinearLayout>

        <!-- ViewFlipper to navigate smoothly between the 6 steps -->
        <ViewFlipper
            android:id="@+id/viewFlipper"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- STEP 1: Location Permission -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location Tracking"
                    android:textSize="24sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Guardian Shield requires location tracking to send real-time coordinates to your parents. Under Android security guidelines, this must be granted in two separate actions."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Card for Fine Location state -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1. GPS Precision Location"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvLocationState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Required"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/indicator_red"
                            android:background="#2D1C1C"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card for Background Location state -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBackgroundLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="24dp"
                    android:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="2. Background Location"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvBackgroundLocationState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Locked"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_muted"
                            android:background="#1E1E1E"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tvLocationExplain"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Important: Background Location allows your parent to see your safety coordinates even when this app is closed or backgrounded."
                    android:textSize="13sp"
                    android:textColor="@color/text_muted"
                    android:layout_marginBottom="32dp"/>

                <Button
                    android:id="@+id/btnLocation"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Grant Location Permissions"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- STEP 2: Accessibility Service -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Accessibility Service"
                    android:textSize="24sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Guardian Shield uses an Accessibility Service to capture screenshots silently for parent-app streaming and to block unapproved applications in real-time."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="20dp"/>

                <!-- Card for status indicator -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Service Status"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvAccessibilityState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inactive"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/indicator_red"
                            android:background="#2D1C1C"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Android 13+ Restricted Settings Bypass Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#1A1C29"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="32dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️ Sideloaded App Notice (Android 13+)"
                            android:textSize="13sp"
                            android:textColor="#3B82F6"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="If the setting is blocked with a 'Restricted Setting' popup:\n1. Go to Settings > Apps > System Services.\n2. Tap the 3 dots in the top-right corner.\n3. Tap 'Allow restricted settings' and confirm.\n4. Return here and tap 'Activate Service' below."
                            android:textSize="12sp"
                            android:textColor="#93C5FD"
                            android:lineSpacingExtra="3dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnAccessibility"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Activate Service"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- STEP 3: Device Administrator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Device Administrator"
                    android:textSize="24sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Activating the Device Admin policy protects the background security services from unauthorized deletion. When enabled, this app cannot be uninstalled without entering the parent's secret PIN."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Card for status indicator -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="48dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Administrator Status"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvAdminState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Inactive"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/indicator_red"
                            android:background="#2D1C1C"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Activate Administrator"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- STEP 4: Usage Stats Access -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App Usage Tracking"
                    android:textSize="24sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Usage Access is required to let parents view today's app usage summaries and enforce application block commands remotely."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Card for status indicator -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="48dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Usage Tracking Status"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvUsageState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Disabled"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/indicator_red"
                            android:background="#2D1C1C"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnUsage"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Grant Usage Access"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- STEP 5: Notification Access -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Notification Safety"
                    android:textSize="24sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Notification Access lets parents analyze incoming communication channels, assisting in scanning for toxic cyberbullying content and security threats."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp"/>

                <!-- Card for status indicator -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="48dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Notification Access"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvNotificationState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Disabled"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/indicator_red"
                            android:background="#2D1C1C"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnNotification"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Grant Notification Access"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <!-- STEP 6: Activation Screen -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Activate Security"
                    android:textSize="24sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Congratulations! You have configured all system prerequisites. Tap the activation button to secure this device, boot protection agents, and trigger invisible stealth mode."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp"/>

                <!-- All Systems Secure Report Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="@color/card_background"
                    app:cardElevation="0dp"
                    android:layout_marginBottom="40dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="System Integrity Check"
                            android:textSize="15sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:layout_marginBottom="16dp"/>

                        <!-- Row indicators -->
                        <TextView
                            android:id="@+id/tvReportLocation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="✓ GPS Location: SECURE"
                            android:textSize="13sp"
                            android:textColor="@color/indicator_green"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvReportAccessibility"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="✓ Accessibility: SECURE"
                            android:textSize="13sp"
                            android:textColor="@color/indicator_green"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvReportAdmin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="✓ Device Administrator: SECURE"
                            android:textSize="13sp"
                            android:textColor="@color/indicator_green"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvReportUsage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="✓ App Usage Logs: SECURE"
                            android:textSize="13sp"
                            android:textColor="@color/indicator_green"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvReportNotification"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="✓ Notification Listener: SECURE"
                            android:textSize="13sp"
                            android:textColor="@color/indicator_green"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/btnActivate"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="Activate Stealth Protection"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

        </ViewFlipper>

        <!-- Footer Control Area for navigation fallbacks -->
        <LinearLayout
            android:id="@+id/layoutFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btnNext"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Next Step →"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:visibility="gone"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
