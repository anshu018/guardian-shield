<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- 1. Background Map -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 2. Header Panel -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="#CC1A1A24"
        android:padding="16dp"
        app:layout_dodgeInsetEdges="top">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GUARDIAN SHIELD"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
            
        <TextView
            android:id="@+id/tvHeaderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="ACTIVE SECURE"
            android:textColor="#10B981"
            android:textSize="12sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Floating Bottom Card for Device Linking PIN when no child is registered -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLinkingPIN"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#CC1C1C24"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡️ Link Child Device"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter this 6-digit family PIN in the Setup Wizard on your child's phone to link devices."
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:gravity="center"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="16dp" />

            <!-- Beautiful 6-digit PIN display panel -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#2E293B"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvLinkingCode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="------"
                    android:textColor="#2563EB"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.4"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Copy button -->
            <Button
                android:id="@+id/btnCopyCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Copy PIN to Clipboard"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2563EB"
                android:layout_marginBottom="16dp"/>

            <!-- Pulse/Loading sync indicator -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <ProgressBar
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:indeterminate="true"
                    android:indeterminateTint="#2563EB"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Waiting for child device to connect..."
                    android:textColor="#94A3B8"
                    android:textSize="12sp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 3. Floating Bottom Child Status Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardChildStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#CC1C1C24">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Child Name and Status Row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/tvChildName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Child"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <!-- Online Status Pill -->
                <LinearLayout
                    android:id="@+id/panelStatusPill"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="#1E293B"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp">

                    <View
                        android:id="@+id/viewStatusDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="center_vertical"
                        android:layout_marginEnd="6dp"
                        android:background="#64748B" />

                    <TextView
                        android:id="@+id/tvStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="OFFLINE"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Metrics Column -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Battery Level Indicator -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Battery Level"
                        android:textColor="#94A3B8" />
                        
                    <TextView
                        android:id="@+id/tvBatteryPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="0%"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Current Running Application -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Current Active App"
                        android:textColor="#94A3B8" />
                        
                    <TextView
                        android:id="@+id/tvActiveApp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="None"
                        android:textColor="#3B82F6"
                        android:textStyle="bold" />
                </RelativeLayout>

                <!-- Last Update Timing -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last Updated"
                        android:textColor="#94A3B8" />
                        
                    <TextView
                        android:id="@+id/tvLastSeen"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="Never"
                        android:textColor="#FFFFFF" />
                </RelativeLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
