<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#CC1C1C24">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">

            <!-- Contact Name or Address -->
            <TextView
                android:id="@+id/tvSmsSender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rahul Sharma"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSmsPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/tvSmsSender"
                android:text="+919876543210"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />

            <!-- Time Stamp -->
            <TextView
                android:id="@+id/tvSmsTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="10:15 AM"
                android:textColor="#64748B"
                android:textSize="11sp" />
        </RelativeLayout>

        <!-- Message Snippet -->
        <TextView
            android:id="@+id/tvSmsBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hey dad, I've reached the tuition center safely. Class starts in 5 minutes."
            android:textColor="#E2E8F0"
            android:textSize="13sp"
            android:lineSpacingMultiplier="1.1" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
