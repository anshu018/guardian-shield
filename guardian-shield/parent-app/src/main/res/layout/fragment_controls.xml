<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- 1. Header with Child Selection Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#CC1C1C24">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="REMOTE COMMANDS CENTER"
                        android:textColor="#94A3B8"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <TextView
                        android:id="@+id/tvActiveChildLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Child Profile"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <Spinner
                    android:id="@+id/spinnerChildren"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:drawable/btn_dropdown"
                    android:theme="@style/ThemeOverlay.AppCompat.Dark"
                    android:gravity="end|center_vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 2. Scrollable Commands Grid/List -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="24dp">

                <!-- Lock Device Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#CC1C1C24">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="INSTANT DEVICE LOCK"
                            android:textColor="#EF4444"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Force Lock Screen"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Instantly forces the child's screen to lock. Requires active Device Administrator permissions on the child app."
                            android:textColor="#94A3B8"
                            android:textSize="12sp"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="16dp" />

                        <Button
                            android:id="@+id/btnLockDevice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="LOCK DEVICE NOW"
                            android:backgroundTint="#EF4444"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:paddingVertical="12dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Siren Alarm Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#CC1C1C24">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="EMERGENCY SIREN"
                            android:textColor="#F59E0B"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sound High-Decibel Siren"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Plays a loud continuous siren on the child's device overriding silent/vibrate streams until cancelled."
                            android:textColor="#94A3B8"
                            android:textSize="12sp"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="16dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnStartSiren"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="START SIREN"
                                android:backgroundTint="#F59E0B"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:layout_marginEnd="8dp"
                                android:paddingVertical="12dp" />

                            <Button
                                android:id="@+id/btnStopSiren"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="STOP SIREN"
                                android:backgroundTint="#475569"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:paddingVertical="12dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Warning Message Overlay Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#CC1C1C24">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PARENTAL NOTICE OVERLAY"
                            android:textColor="#3B82F6"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Send Full-Screen Warning"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Displays a persistent warning overlay on child's device with custom warning text. Block UI operations until dismissed."
                            android:textColor="#94A3B8"
                            android:textSize="12sp"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="12dp" />

                        <EditText
                            android:id="@+id/etWarningMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Type warning message (e.g. Stop playing!)"
                            android:textColorHint="#475569"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:background="#121212"
                            android:padding="12dp"
                            android:layout_marginBottom="12dp"
                            android:inputType="textLongMessage" />

                        <Button
                            android:id="@+id/btnSendMessage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="SEND NOTICE NOW"
                            android:backgroundTint="#3B82F6"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:paddingVertical="12dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Block Applications Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#CC1C1C24">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="APPLICATION BLOCKING"
                            android:textColor="#A855F7"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Remote Package Restricted Settings"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Remotely block specific applications on the child's device using their raw package name."
                            android:textColor="#94A3B8"
                            android:textSize="12sp"
                            android:layout_marginTop="6dp"
                            android:layout_marginBottom="12dp" />

                        <EditText
                            android:id="@+id/etBlockedPackage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Type package name (e.g. com.android.chrome)"
                            android:textColorHint="#475569"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:background="#121212"
                            android:padding="12dp"
                            android:layout_marginBottom="12dp"
                            android:inputType="text" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnBlockApp"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="BLOCK PACKAGE"
                                android:backgroundTint="#A855F7"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:layout_marginEnd="8dp"
                                android:paddingVertical="12dp" />

                            <Button
                                android:id="@+id/btnClearBlocked"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="CLEAR ALL"
                                android:backgroundTint="#475569"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:paddingVertical="12dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Command Status Logs Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#CC1C1C24">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="REAL-TIME FEEDBACK LOG"
                            android:textColor="#94A3B8"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <TextView
                            android:id="@+id/tvFeedbackLog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No commands transmitted in this session yet."
                            android:textColor="#E2E8F0"
                            android:textSize="13sp"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
